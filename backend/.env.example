# MEXC Futures Trading System Configuration
MEXC_API_KEY=your_api_key_here
MEXC_API_SECRET=your_api_secret_here
MEXC_BASE_URL=https://contract.mexc.com
WS_URL=wss://contract.mexc.com/realtime

# Trading Settings
MIN_VOLUME_24H_USD=20000000
CONFIDENCE_THRESHOLD=0.75
MAX_LEVERAGE=20
DEFAULT_LEVERAGE=10
MAX_POSITION_SIZE_USD=1000
STOP_LOSS_PCT=0.02
TAKE_PROFIT_PCT=0.04

# ML Settings
MODEL_CACHE_DIR=./data/models_cache
FEATURE_COUNT=48
TRAINING_TIMEFRAME=4h
PREDICTION_TIMEFRAME=15m

# Server Settings
HOST=0.0.0.0
PORT=8000
DEBUG=false

# Telegram Notifications (Optional)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
